# Template konfigurasi secret. Salin ke `.env` lalu isi nilai asli.
#   cp .env.example .env
# File `.env` TIDAK di-commit (di-ignore git). Jangan taruh nilai asli di sini.

# Token Bearer untuk API backend (scanner-camera)
API_BEARER_TOKEN=ganti-dengan-jwt-token-anda

# URL RTSP kamera (format: rtsp://user:password@host)
RTSP_AO_URL=rtsp://user:password@172.19.95.34
RTSP_QI_URL=rtsp://user:password@172.19.95.21
