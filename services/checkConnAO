#!/bin/bash
# Watchdog konektivitas kamera AO.
# Membaca heartbeat data/state/updateConnAO (ditulis thread detect-ao.py tiap 5 detik).
# Bila basi >TIMEOUT_LIMIT detik -> ping kamera -> restart service camera_ao.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_DIR="$(dirname "$SCRIPT_DIR")"

TIMEOUT_LIMIT=10
PING_TARGET="172.19.95.34"
while true
do
        LAST_TIME=$(cat "$BASE_DIR/data/state/updateConnAO");
        CURRENT_TIME=$(date +%s);

        selisih=$(($CURRENT_TIME-$LAST_TIME));
        echo $selisih;

        if [ "$selisih" -ge "$TIMEOUT_LIMIT" ]; then
		PING_OUTPUT=$(ping -c 1 $PING_TARGET 2>&1)
		PING_STATUS=$?

		if [ $PING_STATUS -eq 0 ]; then
			LATENCY=$(echo "$PING_OUTPUT" | grep -oP 'time=\K\S+')
			LATENCY="${LATENCY} ms"
		else
			LATENCY="UNREACHABLE"
		fi


                echo "RESTARTING CAMERA AO PROGRAM!!!";
                echo -e "\n$(date +"%Y-%m-%d %H:%M:%S") - $LATENCY - Connection Lost from AO Camera" >> "$BASE_DIR/data/logs/connLogAO";
		systemctl restart camera_ao.service
		sleep 15;
        fi;

        sleep 1;
done
